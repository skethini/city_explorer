# LLM provider (defaults to OpenAI gpt-4o-mini).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Foursquare Places API key (https://developer.foursquare.com/).
FOURSQUARE_API_KEY=fsq3...

# Optional: Google Maps Geocoding API key — used for forward/reverse geocoding and
# city center lookup instead of Nominatim (avoids public OSM rate limits). Enable
# Geocoding API on your Google Cloud project. https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# Optional: override the public Overpass and OSRM endpoints if you self-host.
OVERPASS_URL=https://overpass-api.de/api/interpreter
OSRM_URL=https://router.project-osrm.org

# Bind config for uvicorn.
HOST=0.0.0.0
PORT=8000
