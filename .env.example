# LLM provider (required).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional: Google Maps Geocoding API — forward/reverse geocoding and city lookup
# instead of Nominatim (recommended for production). Enable Geocoding API on your
# Google Cloud project. https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# Optional: override the public OSRM endpoint if you self-host.
OSRM_URL=https://router.project-osrm.org

# Bind config for uvicorn.
HOST=0.0.0.0
PORT=8000
